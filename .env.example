# Chain: 84532 = Base Sepolia (dev), 8453 = Base mainnet (prod)
NEXT_PUBLIC_CHAIN_ID=84532

# App URL (set by Vercel automatically, or override for local)
NEXT_PUBLIC_URL=http://localhost:3000

# YoCAExecutor contract address (deployed)
NEXT_PUBLIC_YOCA_CONTRACT=0x...

# --- Testnet only: mock contract addresses (from DeployTestnet.s.sol output) ---
NEXT_PUBLIC_MOCK_YOUSD=0x...
NEXT_PUBLIC_MOCK_YOEUR=0x...
NEXT_PUBLIC_MOCK_YOETH=0x...
NEXT_PUBLIC_MOCK_YOBTC=0x...
NEXT_PUBLIC_MOCK_SWAP_ROUTER=0x...

# Neon PostgreSQL
DATABASE_URL=postgresql://...@...neon.tech/yoca?sslmode=require

# Backend wallet for cron-based DCA execution
KEEPER_PRIVATE_KEY=0x...

# Vercel cron secret
CRON_SECRET=...

# DEX aggregator API key (0x, 1inch, or Odos) -- mainnet only
DEX_AGGREGATOR_API_KEY=...

# Base RPC (defaults to public if not set)
BASE_RPC_URL=https://sepolia.base.org

# Base Builder Code (from base.dev > Settings > Builder Codes)
NEXT_PUBLIC_BUILDER_CODE=bc_...
